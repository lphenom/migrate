{
    "name": "lphenom/migrate",
    "description": "LPhenom CLI migration tool — apply, rollback and inspect database migrations",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "dmitrii-pov",
            "email": "popkovd.o@yandex.ru"
        }
    ],
    "require": {
        "php": ">=8.1",
        "lphenom/db": "^0.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.40 <3.65",
        "ext-pdo_sqlite": "*"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/lphenom/db"
        }
    ],
    "autoload": {
        "psr-4": {
            "LPhenom\\Migrate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LPhenom\\Migrate\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/migrate"
    ],
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.1.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint-fix": "php-cs-fixer fix",
        "analyse": "phpstan analyse"
    }
}

